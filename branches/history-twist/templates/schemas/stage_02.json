{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["event","protagonist","perspectives","recommended","controversy_score","shareability"],
  "properties": {
    "event": {"type": "string"},
    "protagonist": {"type": "string"},
    "perspectives": {
      "type": "array",
      "minItems": 3,
      "maxItems": 3,
      "items": {
        "type": "object",
        "required": ["id","model","one_liner","evidence","reasoning","twist_level","risk"],
        "properties": {
          "id": {"type": "integer"},
          "model": {"type": "string"},
          "one_liner": {"type": "string"},
          "evidence": {"type": "string"},
          "reasoning": {"type": "string"},
          "twist_level": {"type": "string","enum": ["S","A","B","C"]},
          "risk": {"type": "string","enum": ["低","中","高"]}
        }
      }
    },
    "recommended": {
      "type": "object",
      "required": ["id","rationale"],
      "properties": {
        "id": {"type": "integer"},
        "rationale": {"type": "string"}
      }
    },
    "controversy_score": {"type": "number","minimum": 0,"maximum": 10},
    "shareability": {"type": "string"}
  }
}